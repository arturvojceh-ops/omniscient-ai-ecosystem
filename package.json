    "winston-daily-rotate-file": "^4.7.0",
    "prometheus-client": "^15.0.0",
    "grafana-api": "^1.0.0",
    "dotenv": "^16.3.0",
    "joi": "^17.11.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "axios": "^1.6.0",
    "ws": "^8.14.0",
    "socket.io": "^4.7.0"
