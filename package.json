{
  "name": "omniscient-ai-ecosystem",
  "version": "1.0.0",
  "description": "Transcendent AI Agent System with Omniscient Intelligence - Built with LangGraph S-Tier, Claude 4.6, and Cursor AI Ultimate Features",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon --exec ts-node src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "k8s:deploy": "kubectl apply -f k8s/",
    "k8s:delete": "kubectl delete -f k8s/",
    "security:scan": "npm audit",
    "security:fix": "npm audit fix",
    "performance:test": "artillery run performance-test.yml",
    "monitoring:start": "npm run start:prometheus && npm run start:grafana",
    "start:prometheus": "prometheus --config.file=prometheus.yml",
    "start:grafana": "grafana-server --config=grafana.ini"
  },
  "keywords": [
    "ai-agents",
    "langgraph",
    "claude-4.6",
    "cursor-ai",
    "enterprise-ai",
    "multi-agent-systems",
    "production-ready",
    "typescript",
    "nodejs",
    "kubernetes",
    "docker",
    "microservices",
    "security",
    "monitoring",
    "scalability"
  ],
  "author": "Omniscient AI Developer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/omniscient-ai-ecosystem.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/omniscient-ai-ecosystem/issues"
  },
  "homepage": "https://github.com/your-username/omniscient-ai-ecosystem#readme",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.2.0",
    "@langchain/anthropic": "^0.2.0",
    "@langchain/core": "^0.3.0",
    "@anthropic-ai/sdk": "^0.24.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/graphql": "^12.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@prisma/client": "^5.0.0",
    "@prisma/adapter": "^5.0.0",
    "apollo-server-express": "^3.12.0",
    "graphql": "^16.8.0",
    "graphql-subscriptions": "^2.0.0",
    "redis": "^4.6.0",
    "ioredis": "^5.3.0",
    "pg": "^8.11.0",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
